.box {
    width: 200px;
    padding: 20px;
    border: 5px solid black;
    margin: 20px;
    background: lightblue;
}

.broken-box {
    width: 300px;
    padding: 20px;
    box-sizing: border-box;
}


.card {
    width: 300px;
    padding: 20px;
    border: 1px solid gray;
}

.card img {
    width: 100%;
}

.card h3 {
    margin-bottom: 15px;
}




